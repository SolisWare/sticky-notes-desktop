{
  "name": "x-notes",
  "productName": "X-NoTES",
  "description": "Cross platform X-NoTES desktop client written in ReactJS + Electron",
  "version": "0.1.0",
  "private": true,
  "author": {
    "name": "SolisWare",
    "email": "solisware@mail.com",
    "url": "https://solisware.com"
  },
  "main": "build/electron/electron.js",
  "homepage": "./",
  "build": {
    "appId": "com.solisware.xnotes",
    "productName": "X-NoTES",
    "copyright": "Copyright © 2023-2026 ${author}",
    "mac": {
      "category": "public.app-category.productivity"
    },
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "license": "LICENSE.txt",
      "shortcutName": "X-NoTES",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "extraMetadata": {
      "main": "build/electron/electron.js"
    },
    "files": [
      "package.json",
      "build/**/*",
      "node_modules/**/*"
    ]
  },
  "scripts": {
    "clean": "rm -rf build dist",
    "start:web": "react-scripts start",
    "build:web": "PUBLIC_URL=./ react-scripts build",
    "build:desktop": "tsc -p electron/tsconfig.json",
    "build": "npm run build:web && npm run build:desktop",
    "start:desktop": "npm run build:desktop && electron ./build/electron.js",
    "electron:dev": "concurrently \"BROWSER=none npm run start:web\" \"wait-on http://localhost:3000 && npm run build && electron ./build/electron/electron.js\"",
    "dist-mac": "electron-builder -m",
    "dist-windows": "electron-builder -w"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "dependencies": {
    "@emotion/react": "^11.11.1",
    "@emotion/styled": "^11.11.0",
    "@mui/icons-material": "^5.14.15",
    "@mui/material": "^5.14.15",
    "@mui/styles": "^5.14.15",
    "@testing-library/jest-dom": "^6.1.4",
    "@testing-library/react": "^14.0.0",
    "@testing-library/user-event": "^14.5.1",
    "@types/jest": "^29.5.6",
    "@types/node": "^20.8.9",
    "@types/react": "^18.2.33",
    "@types/react-dom": "^18.2.14",
    "electron-is-dev": "^2.0.0",
    "electron-router-dom": "^1.0.5",
    "react": "^18.2.0",
    "react-autosave": "^0.4.4",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.17.0",
    "react-scripts": "5.0.1",
    "typescript": "^5.2.2",
    "web-vitals": "^3.5.0"
  },
  "devDependencies": {
    "@electron/remote": "^2.0.12",
    "concurrently": "^8.2.2",
    "electron": "^27.0.2",
    "electron-builder": "^24.6.4",
    "wait-on": "^7.0.1"
  }
}
