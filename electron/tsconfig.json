{
  "compilerOptions": {
    "module": "commonjs",
    "outDir": "../build",
    "baseUrl": ".",
    "noImplicitAny": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "paths": {
      "*":["node_modules/*"]
    }
  },
  "include": [
    "**/*",
    "../scripts/app-version/**/*",
    "../config/**/*"
  ]
}
