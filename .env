# Forces the app to run in development mode.
# This enables the local development flow, including loading the dev server, hot reloading, and opening Electron debug tools.
ELECTRON_IS_DEV=true

# Optional CI build number override for app versioning (appends a build suffix like -b123).
# GitHub Actions provides GITHUB_RUN_NUMBER automatically, but you can uncomment this for local testing.
# GITHUB_RUN_NUMBER=123
